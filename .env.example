# Copy this file to .env and fill in your EmailJS credentials
# Get free keys at https://emailjs.com
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxx

# For GitHub Pages deployment — set to /your-repo-name/
# Leave empty for custom domain or root deployment
VITE_BASE_PATH=/chandana-portfolio/
